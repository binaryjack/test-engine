{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Frontend Server",
            "type": "shell",
            "command": "pnpm dev",
            "cwd": "${workspaceFolder}/test-machine/frontend",
            "isBackground": true,
            "problemMatcher": {
                "owner": "typescript",
                "pattern": {
                    "regexp": "^.*$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "ready in|http://localhost:5174"
                }
            }
        }
    ]
}